<odoo>
    <record id="action_product_report" model="ir.actions.report">
        <field name="name">Product Catalog</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bridge_product_report.product_report_template</field>
        <field name="report_file">bridge_product_report.product_report_template</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Product - %s' % (object.name)</field>
    </record>
</odoo>