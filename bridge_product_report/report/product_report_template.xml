<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="product_report_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Product Catalog</h2>
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Internal Ref</th>
                                <th>Type</th>
                                <th>Category</th>
                                <th>Sales Price</th>
                                <th>Cost</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="p">
                                <tr>
                                    <td><span t-field="p.name"/></td>
                                    <td><span t-field="p.default_code"/></td>
                                    <td><span t-field="p.detailed_type"/></td>
                                    <td><span t-field="p.categ_id"/></td>
                                    <td><span t-field="p.list_price"/></td>
                                    <td><span t-field="p.standard_price"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
