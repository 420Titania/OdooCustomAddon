<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="product_report_template">
        <t t-call="web.html_container">
            <div class="page" style="margin: 0; padding: 0;">

                <!-- HEADER -->
                <div style="text-align: center; margin: 0 0 10px 0; padding-top: 0;">
                    <img t-if="logo_base64"
                        t-att-src="'data:%s;base64,%s' % (logo_mime, logo_base64)"
                        style="height: 80px; float:left;"/>

                    <h3 style="margin:0;">GEREJA SANTA BERNADET PAROKI PINANG</h3>
                    <div>Perawatan dan Pemeliharaan Komplek Gereja (PPKG)</div>
                    <div>Jl. Boulevard Graha Raya Kav. 12, Kel. Sudimara Pinang, Kec. Pinang</div>
                    <div>Kota Tangerang, 15220</div>

                    <div style="border-top: 2px solid black; margin-top: 10px;"></div>
                </div>

                <!-- TITLE -->
                <p style="margin-top: 10px;">
                    Lampiran Berita Acara poin 1, Daftar List Aset Rusak, Hilang, dan dihibahkan.
                </p>

                <!-- TABLE -->
                <table style="width:100%; border-collapse: collapse; font-size: 12px; line-height: 1.2;">
                    <thead>
                        <tr style="background-color: #e6a57e;">
                            <th style="border:1px solid black;">No.</th>
                            <th style="border:1px solid black;">Lokasi</th>
                            <th style="border:1px solid black;">Kode Bar Code</th>
                            <th style="border:1px solid black;">Nama Aset &amp; Deskripsi</th>
                            <th style="border:1px solid black;">Merk &amp; Type</th>
                            <th style="border:1px solid black;">STATUS</th>
                            <th style="border:1px solid black;">Total (unit)</th>
                            <th style="border:1px solid black;">Lokasi Simpan saat ini</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-set="i" t-value="1"/>
                        <t t-foreach="docs" t-as="p">
                            <tr>
                                <td style="border:1px solid black; text-align:center; vertical-align: top; padding: 4px 6px; height: 2.4em;">
                                    <t t-esc="i"/>
                                </td>
                                <td style="border:1px solid black; vertical-align: top; padding: 4px 6px; height: 2.4em;">
                                    <span t-field="p.x_location"/>
                                </td>
                                <td style="border:1px solid black; vertical-align: top; padding: 4px 6px; height: 2.4em;">
                                    <span t-field="p.barcode"/>
                                </td>
                                <td style="border:1px solid black; vertical-align: top; padding: 4px 6px; height: 2.4em;">
                                    <span t-field="p.name"/>
                                </td>
                                <td style="border:1px solid black; vertical-align: top; padding: 4px 6px; height: 2.4em;">
                                    <span t-field="p.x_brand"/>
                                </td>
                                <td style="border:1px solid black; vertical-align: top; padding: 4px 6px; height: 2.4em;">
                                    <span t-field="p.x_condition_status"/>
                                </td>
                                <td style="border:1px solid black; text-align:center; vertical-align: top; padding: 4px 6px; height: 2.4em;">1</td>
                                <td style="border:1px solid black; vertical-align: top; padding: 4px 6px; height: 2.4em;"></td>
                            </tr>

                            <t t-set="i" t-value="i + 1"/>
                        </t>
                    </tbody>
                </table>

                <div style="width: 34%; margin-left: auto; margin-top: 16px; font-size: 12px;">
                    <t t-set="ss" t-value="status_summary or {}"/>
                    <div style="font-weight: 700; margin-bottom: 4px; text-align: right;">Rekap Status Aset</div>
                    <table style="width:100%; border-collapse: collapse;">
                        <tr>
                            <td style="border:1px solid black; padding: 4px 6px;">Baik</td>
                            <td style="border:1px solid black; padding: 4px 6px; text-align: center;" t-esc="ss.get('baik', 0)"/>
                        </tr>
                        <tr>
                            <td style="border:1px solid black; padding: 4px 6px;">Broken</td>
                            <td style="border:1px solid black; padding: 4px 6px; text-align: center;" t-esc="ss.get('broken', 0)"/>
                        </tr>
                        <tr>
                            <td style="border:1px solid black; padding: 4px 6px;">Rusak</td>
                            <td style="border:1px solid black; padding: 4px 6px; text-align: center;" t-esc="ss.get('rusak', 0)"/>
                        </tr>
                        <tr>
                            <td style="border:1px solid black; padding: 4px 6px;">Dihibahkan</td>
                            <td style="border:1px solid black; padding: 4px 6px; text-align: center;" t-esc="ss.get('dihibahkan', 0)"/>
                        </tr>
                        <tr>
                            <td style="border:1px solid black; padding: 4px 6px;">Tidak Ada</td>
                            <td style="border:1px solid black; padding: 4px 6px; text-align: center;" t-esc="ss.get('tidak_ada', 0)"/>
                        </tr>
                    </table>
                </div>

            </div>
        </t>
    </template>
</odoo>