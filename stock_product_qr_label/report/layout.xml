<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- ===================================================== -->
    <!-- CLEAN EXTERNAL LAYOUT (LABEL SAFE) -->
    <!-- ===================================================== -->
    <template id="external_layout_quant_product_label">
        <t t-if="not o" t-set="o" t-value="doc" />

        <!-- Multicompany handling -->
        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id" />
            </t>
            <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                <t t-set="company" t-value="o.company_id.sudo()" />
            </t>
            <t t-else="">
                <t t-set="company" t-value="res_company" />
            </t>
        </t>

        <!-- MINIMAL WRAPPER (NO ODOO REPORT CLASSES) -->
        <div
            t-attf-class="o_company_#{company.id}_layout"
            t-att-data-oe-model="o and o._name"
            t-att-data-oe-id="o and o.id"
            t-att-data-oe-lang="o and o.env.context.get('lang')"
            style="margin: 0; padding: 0;"
        >
            <t t-out="0" />
        </div>

    </template>

    <!-- ===================================================== -->
    <!-- OPTIONAL: WIZARD VERSION (CLEANED TOO) -->
    <!-- ===================================================== -->
    <template id="external_layout_product_label_wizard_standard">
        <div
            t-attf-class="o_company_#{company.id}_layout"
            t-att-data-oe-model="o and o._name"
            t-att-data-oe-id="o and o.id"
            t-att-data-oe-lang="o and o.env.context.get('lang')"
            style="margin: 0; padding: 0;"
        >
            <t t-out="0" />
        </div>
    </template>

    <template id="external_layout_product_label_wizard">
        <t t-if="not o" t-set="o" t-value="doc" />

        <t t-if="not company">
            <t t-if="company_id">
                <t t-set="company" t-value="company_id" />
            </t>
            <t t-elif="o and 'company_id' in o and o.company_id.sudo()">
                <t t-set="company" t-value="o.company_id.sudo()" />
            </t>
            <t t-else="">
                <t t-set="company" t-value="res_company" />
            </t>
        </t>

        <t t-call="stock_product_qr_label.external_layout_product_label_wizard_standard">
            <t t-out="0" />
        </t>
    </template>

</odoo>