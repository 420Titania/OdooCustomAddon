<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="stock_product_qr_label_document">
        <t t-call="stock_product_qr_label.external_layout_quant_product_label">
            <div style="position: relative; width: 100%; min-height: 40mm; margin: 0; padding: 0; overflow: hidden; page-break-after: always;">
            <div data-png-canvas="1" style="font-family: Helvetica, Arial, sans-serif; width: 80mm; height: 40mm; padding: 0.3mm; margin: 0; box-sizing: border-box; overflow: hidden; display: flex; flex-direction: column; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);">
                <div style="text-align: center; font-size: 15px; font-weight: 700; line-height: 1.1; margin-bottom: 0.6mm;">
                    St. BERNADET - PAROKI PINANG
                </div>
                <div style="border-top: 1px solid #000; margin-bottom: 0.8mm;" />

                <div style="display: table; width: 100%; table-layout: fixed; height: 27mm; margin-bottom: 0.8mm;">
                    <div style="display: table-cell; width: 20mm; vertical-align: middle;">
                        <div style="width: 20mm; height: 20mm; border: 1px solid #000; overflow: hidden;">
                            <img src="/stock_product_qr_label/static/src/img/logo.png" style="width: 100%; height: 100%; display: block;" alt="Company logo" />
                        </div>
                    </div>
                    <div style="display: table-cell; width: 30mm; vertical-align: middle; padding-left: 0.8mm; padding-right: 0.8mm;">
                        <div style="font-size: 12px; font-weight: 700; line-height: 1.2; word-wrap: break-word; overflow-wrap: break-word;">
                            <span t-esc="doc.product_id.default_code or ''" />
                        </div>
                        <div style="font-size: 11.5px; line-height: 1.2; margin-top: 0.8mm; word-wrap: break-word; overflow-wrap: break-word; max-height: 10mm; overflow: hidden;">
                            <span t-esc="doc.product_id.name_for_labels or doc.product_id.name or ''" />
                        </div>
                    </div>
                    <div style="display: table-cell; width: 28mm; vertical-align: middle; text-align: left;">
                        <div style="width: 20mm; height: 22mm; display: block;">
                            <img
                                t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s'%('QR', (qr_code or '').replace(chr(38), '%26').replace('#', '%23'), 88, 88)"
                                style="width: 100%; height: 100%; display: block;"
                            />
                        </div>
                    </div>
                </div>

                                <div style="width: 100%; height: 12mm; display: flex; align-items: center; justify-content: center;">
                    <img
                            style="width: 80mm; height: 12mm; margin-top: 2px;"
                            t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s'%('barcode', (barcode_value or '').replace(chr(38), '%26').replace('#', '%23'), 320, 32)"
            />
                </div>
            </div>
            </div>
        </t>
    </template>

    <template id="report_stock_product_qr_label">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="company" t-value="doc.company_id or env.company" />
                <t t-set="qr_code" t-value="doc.product_id.x_product_url or ''" />
                <t t-set="barcode_value" t-value="doc.product_id.barcode or ''" />
                <t
          t-call="stock_product_qr_label.stock_product_qr_label_document"
          t-lang="company.partner_id.lang"
        />
            </t>
            <t t-call="stock_product_qr_label.report_png_helper"/>
        </t>
    </template>

    <record id="action_stock_product_qr_label_report" model="ir.actions.report">
        <field name="name">Product QR Label</field>
        <field name="model">stock.quant</field>
        <field name="report_type">qweb-html</field>
        <field
      name="report_name"
    >stock_product_qr_label.report_stock_product_qr_label</field>
        <field
      name="report_file"
    >stock_product_qr_label.report_stock_product_qr_label</field>
        <field
      name="print_report_name"
    >('QR Label For Product - %s' % (object.product_id.name))</field>
        <field name="binding_model_id" ref="stock.model_stock_quant" />
        <field name="binding_type">report</field>
        <field
      name="paperformat_id"
      ref="stock_product_qr_label.paperformat_product_qr_label"
    />
    </record>
</odoo>
