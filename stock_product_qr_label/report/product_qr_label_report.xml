<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <!-- ===================================================== -->
    <!-- LABEL TEMPLATE -->
    <!-- ===================================================== -->
    <template id="product_qr_label_document">
        <t t-call="stock_product_qr_label.external_layout_quant_product_label">
            <div data-png-canvas="1" style="font-family: Helvetica, Arial, sans-serif; width: 80mm; height: 40mm; padding: 0.5mm; margin: 0; box-sizing: border-box; overflow: hidden; display: flex; flex-direction: column; page-break-after: always;">

            <div style="text-align: center; font-size: 15px; font-weight: 700; line-height: 1.1; margin-bottom: 0.5mm;">
                St. BERNADET - PAROKI PINANG
            </div>

            <div style="border-top: 1px solid #000; margin-bottom: 0.5mm;"></div>

            <div style="display: flex; width: 100%; margin-bottom: 0.5mm;">
                <div style="width: 20mm;">
                    <div style="width: 20mm; height: 20mm; overflow: hidden;">
                        <img src="/stock_product_qr_label/static/src/img/logo.png" style="width: 100%; height: 100%; display: block;" alt="Company logo" />
                    </div>
                </div>

                <div style="flex: 1; padding: 0 1mm;">
                    <div style="font-size: 11px; font-weight: 700; line-height: 1.1; word-wrap: break-word;">
                        <span t-esc="doc.name_for_labels or doc.name or ''"/>
                    </div>

                    <div style="font-size: 10.5px; line-height: 1.1; margin-top: 0.5mm; word-wrap: break-word; max-height: 10mm; overflow: hidden;">
                        <span t-esc="doc.default_code or ''"/>
                    </div>
                </div>

                <div style="width: 22mm; display: flex; justify-content: flex-start;">
                    <img style="width: 20mm; height: 20mm;"
                         t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s'%('QR', (qr_code or '').replace(chr(38), '%26').replace('#', '%23'), 90, 90)"/>
                </div>
            </div>

            <div style="width: 100%; height: 12mm; display: flex; align-items: center; justify-content: center;">
                <img style="width: 100%; height: 12mm; margin-top: 2px;"
                     t-att-src="'/report/barcode/?barcode_type=%s&amp;value=%s&amp;width=%s&amp;height=%s'%('Code128', (barcode_value or '').replace(chr(38), '%26').replace('#', '%23'), 640, 96)"/>
            </div>
            </div>
        </t>
    </template>

    <!-- ===================================================== -->
    <!-- REPORT (product.product) -->
    <!-- ===================================================== -->
    <template id="report_product_qr_label">
        <t t-call="web.html_container">
            <t t-set="company" t-value="env.company"/>
            <t t-foreach="docs" t-as="doc">

                <t t-set="qr_code" t-value="doc.x_product_url or ''"/>
                <t t-set="barcode_value" t-value="doc.barcode or ''"/>

                <t t-call="stock_product_qr_label.product_qr_label_document"
                   t-lang="company.partner_id.lang"/>

            </t>
            <t t-call="stock_product_qr_label.report_png_helper"/>
        </t>
    </template>

    <!-- ===================================================== -->
    <!-- REPORT (product.template) -->
    <!-- ===================================================== -->
    <template id="report_template_qr_label">
        <t t-call="web.html_container">
            <t t-set="company" t-value="env.company"/>
            <t t-foreach="docs" t-as="doc">

                <t t-set="qr_code" t-value="doc.x_product_url or ''"/>
                <t t-set="barcode_value" t-value="doc.barcode or ''"/>

                <t t-call="stock_product_qr_label.product_qr_label_document"
                   t-lang="company.partner_id.lang"/>

            </t>
            <t t-call="stock_product_qr_label.report_png_helper"/>
        </t>
    </template>

    <!-- ===================================================== -->
    <!-- ACTIONS -->
    <!-- ===================================================== -->
    <record id="action_product_qr_label_report" model="ir.actions.report">
        <field name="name">QR Label</field>
        <field name="model">product.product</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">stock_product_qr_label.report_product_qr_label</field>
        <field name="report_file">stock_product_qr_label.report_product_qr_label</field>
        <field name="print_report_name">'QR Label - %s' % (object.name)</field>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="stock_product_qr_label.paperformat_product_qr_label"/>
    </record>

    <record id="action_template_qr_label_report" model="ir.actions.report">
        <field name="name">QR Label</field>
        <field name="model">product.template</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">stock_product_qr_label.report_template_qr_label</field>
        <field name="report_file">stock_product_qr_label.report_template_qr_label</field>
        <field name="print_report_name">'QR Label - %s' % (object.name)</field>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="stock_product_qr_label.paperformat_product_qr_label"/>
    </record>

</odoo>